# OpenAI model used by the one-shot intent compiler and demo agent.
OPENAI_MODEL=gpt-5.6
# Set locally; never commit a populated .env file.
OPENAI_API_KEY=

# Optional: enables LangFuse traces for intent and verdict metadata only.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
